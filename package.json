{
  "name": "starboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "biome check .",
    "biome:lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed-embeddings": "tsx src/db/seed-embeddings.ts",
    "db:embed-pending": "tsx src/db/seed-embeddings.ts",
    "db:enrich-repos": "tsx scripts/enrich-repos.ts",
    "db:seed-popular": "tsx scripts/seed-popular.ts",
    "db:enrich-tools": "tsx scripts/enrich-tools.ts",
    "fleet:audit-recommendation-context": "tsx scripts/audit-fleet-recommendation-context.ts",
    "fleet:extract-projects": "tsx scripts/extract-fleet-projects.ts",
    "weekly:threshold-digest": "tsx scripts/weekly-threshold-digest.ts",
    "digest:send-emails": "tsx scripts/send-weekly-digest-emails.ts",
    "cf:build": "next build --webpack && node scripts/run-inline-critical-css.mjs && opennextjs-cloudflare build --skipNextBuild && opennextjs-cloudflare populateCache local && pnpm --filter ./landing-astro build && node scripts/run-overlay-astro-landing.mjs",
    "build:cf": "next build --webpack && node scripts/run-inline-critical-css.mjs && opennextjs-cloudflare build --skipNextBuild && opennextjs-cloudflare populateCache local && pnpm --filter ./landing-astro build && node scripts/run-overlay-astro-landing.mjs",
    "preview:cf": "pnpm build:cf && opennextjs-cloudflare preview",
    "deploy:cf": "pnpm build:cf && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke:knowledgebase": "node scripts/smoke-knowledgebase.mjs",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile",
    "docs:check": "node scripts/check-docs.mjs",
    "docs:dev": "blume dev",
    "docs:build": "blume build",
    "prepare": "husky"
  },
  "dependencies": {
    "@libsql/client": "0.17.3",
    "@saas-maker/changelog-widget": "^0.2.1",
    "@saas-maker/feedback": "^0.2.1",
    "@saas-maker/testimonials": "^0.2.1",
    "@tanstack/react-virtual": "3.13.24",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.11.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "0.4.6",
    "nuqs": "2.8.9",
    "posthog-js": "^1.372.1",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "swr": "2.4.1",
    "tailwind-merge": "3.5.0",
    "web-vitals": "^4.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@opennextjs/cloudflare": "1.19.4",
    "@tailwindcss/postcss": "4",
    "@types/node": "25.6.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitest/coverage-v8": "4.1.5",
    "babel-plugin-react-compiler": "1.0.0",
    "beasties": "^0.3.5",
    "husky": "9.1.7",
    "shadcn": "4.4.0",
    "tailwindcss": "4",
    "tsx": "^4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "wrangler": "4.85.0"
  }
}
