---
import '@/styles/landing.css';
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const SITE_URL = 'https://starboard.sarthakagrawal927.workers.dev';
// OG image lives on the Next.js Worker at /opengraph-image (Next file
// convention → dynamic JSX → PNG). The single-Worker overlay keeps that
// route on the OpenNext side, so this URL still resolves.
const OG_IMAGE = `${SITE_URL}/opengraph-image`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content="Starboard" />
    <meta
      name="keywords"
      content="GitHub stars, repository organizer, semantic search, open source discovery"
    />

    <link rel="canonical" href={SITE_URL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:site_name" content="Starboard" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={OG_IMAGE} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />

    {/* ── Fonts ────────────────────────────────────────────────────
       Self-hosted via @fontsource-variable/{geist,geist-mono} (imported
       in the frontmatter). Astro/Vite inlines the @font-face into the
       page CSS and serves the woff2 from /_astro/ same-origin, so there
       is no external CSS fetch on the LCP path. font-display: swap is
       preserved by Fontsource. Only Geist (the LCP-h1 face) is the
       critical path; Geist Mono is shipped alongside but is not
       LCP-critical. */}

    {/* Wire the same CSS vars Next.js's next/font sets up, so any
       Tailwind class using --font-geist-sans / --font-geist-mono keeps
       working without a rebuild. Fontsource registers the families as
       'Geist Variable' / 'Geist Mono Variable'. */}
    <style is:inline>
      :root {
        --font-geist-sans: 'Geist Variable', system-ui, -apple-system, sans-serif;
        --font-geist-mono: 'Geist Mono Variable', ui-monospace, Menlo, monospace;
      }
      html.dark { color-scheme: dark; }
      body { margin: 0; }
    </style>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
